^https?:\/\/dtrip\.xiaojukeji\.com\/poly-rebuild\/pages\/home\/index\?(?:[^#]*&)?dchn=M5Rj3dB(?:&|$)(?:[^#]*)$ data-type=text data="<!doctype html><html></html>" status-code=200 header="Content-Type:text/html; charset=utf-8"
^https?:\/\/(?:(?:s1-static|s1-staticpcdn|xy-s1-staticpcdn|qn-s1-staticpcdn)\.msstatic\.com)\/kiwi-lizard-(?:AdvertisingDetailTip|BigCardAd|GameAd|LaunchAlert|LiveRoomFloatVideoAD(?:New)?|PubScreenVideoAd(?:Element(?:New)?|New)?|RewardPlanAd|SaharaBusiAd(?:Cpn(?:NewOne)?|List)|SaharaMyTabAdBanner|SmallAd(?:One(?:Test)?|Two)|SubscribeSmallCardAd)\/kiwi_lizard\/[^/?#]+\/\d+\/[^/?#]+\.ios\.lzc(?:\?.*)?$ data-type=text data="" status-code=204
